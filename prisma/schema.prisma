generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                String             @id @default(uuid())
  email             String             @unique
  provider          String
  providerId        String?            @unique
  role              UserRole           @default(USER)
  fullName          String
  dateOfBirth       DateTime?
  gender            Gender?
  height            Float?
  weight            Float?
  activityLevel     ActivityLevel?
  createdAt         DateTime           @default(now())
  lastLogin         DateTime?

  // Relations
  aiRecommendations AIRecommendation[]
  diseases          Disease[]
  medications       Medication[]
  exercisePlans     ExercisePlan[]
  goals             Goal[]
  healthInfo        HealthInfo?
  nutritionPlan     NutritionPlan?
  reminders         Reminder[]
  sleepSchedule     SleepSchedule?
}

model HealthInfo {
  id                String   @id @default(uuid())
  userId            String   @unique
  hasChronicDisease Boolean
  allergies         String[]
  notes             String?
  createdAt         DateTime @default(now())
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Disease {
  id            String       @id @default(uuid())
  userId        String
  diseaseType   DiseaseType
  diseaseName   String
  diagnosedDate DateTime
  description   String?
  createdAt     DateTime     @default(now())

  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  medications   Medication[]

  @@index([userId])
}

model Medication {
  id             String     @id @default(uuid())
  userId         String
  diseaseId      String
  medicationName String
  dosage         String
  timesPerDay    Int
  startDate      DateTime
  endDate        DateTime?
  instructions   String?
  createdAt      DateTime   @default(now())

  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  disease        Disease          @relation(fields: [diseaseId], references: [id], onDelete: Cascade)
  reminders      Reminder[]       @relation("MedicationReminders")
  times          MedicationTime[]

  @@index([userId])
  @@index([diseaseId])
}

model MedicationTime {
  id            String     @id @default(uuid())
  medicationId  String
  time          String
  createdAt     DateTime   @default(now())

  medication    Medication @relation(fields: [medicationId], references: [id], onDelete: Cascade)

  @@unique([medicationId, time])
  @@index([medicationId])
}

model Goal {
  id           String    @id @default(uuid())
  userId       String
  goalType     GoalType
  targetWeight Float?
  targetDate   DateTime?
  description  String?
  createdAt    DateTime  @default(now())

  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model NutritionPlan {
  id            String   @id @default(uuid())
  userId        String   @unique
  dailyCalories Int
  proteinGrams  Int
  carbsGrams    Int
  fatsGrams     Int
  startDate     DateTime
  createdAt     DateTime @default(now())

  meals         Meal[]
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  reminders     Reminder[] @relation("NutritionReminders")
}

model Meal {
  id              String        @id @default(uuid())
  nutritionPlanId String
  mealName        String
  mealTime        String
  description     String
  calories        Int
  protein         Int
  carbs           Int
  fats            Int
  createdAt       DateTime      @default(now())
  
  nutritionPlan   NutritionPlan @relation(fields: [nutritionPlanId], references: [id], onDelete: Cascade)
  reminders       Reminder[]    @relation("MealReminders")

  @@index([nutritionPlanId])
}

model ExercisePlan {
  id           String   @id @default(uuid())
  userId       String
  exerciseName String
  exerciseType String
  duration     Int
  frequency    String
  instructions String?
  createdAt    DateTime @default(now())

  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  reminders     Reminder[] @relation("ExerciseReminders")

  @@index([userId])
}

model SleepSchedule {
  id          String   @id @default(uuid())
  userId      String   @unique
  bedTime     String
  wakeTime    String
  targetHours Float
  createdAt   DateTime @default(now())

  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  reminders   Reminder[] @relation("SleepReminders")
}

model Reminder {
  id                 String         @id @default(uuid())
  userId             String
  type               ReminderType
  reminderTime       DateTime
  status             ReminderStatus
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  // Foreign Keys for polymorphic relations
  medicationId       String?
  mealId             String?
  exercisePlanId     String?
  sleepScheduleId    String?
  nutritionPlanId    String?

  user               User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  medication         Medication?     @relation("MedicationReminders", fields: [medicationId], references: [id], onDelete: Cascade)
  meal               Meal?           @relation("MealReminders", fields: [mealId], references: [id], onDelete: Cascade)
  exercisePlan       ExercisePlan?   @relation("ExerciseReminders", fields: [exercisePlanId], references: [id], onDelete: Cascade)
  sleepSchedule      SleepSchedule?  @relation("SleepReminders", fields: [sleepScheduleId], references: [id], onDelete: Cascade)
  nutritionPlan      NutritionPlan?  @relation("NutritionReminders", fields: [nutritionPlanId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@index([status])
  @@index([reminderTime])
  @@index([medicationId])
  @@index([mealId])
  @@index([exercisePlanId])
  @@index([sleepScheduleId])
  @@index([nutritionPlanId])
}

model AIRecommendation {
  id                 String   @id @default(uuid())
  userId             String
  recommendationType String
  recommendation     String
  createdAt          DateTime @default(now())

  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ===== ENUMS =====
enum ReminderType {
  MEDICATION
  EXERCISE
  MEAL
  SLEEP
  NUTRITION
}

enum ReminderStatus {
  PENDING
  COMPLETED
  MISSED
}

enum UserRole {
  USER
  ADMIN
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum DiseaseType {
  CANCER
  DIABETES
  HYPERTENSION
  HEART_DISEASE
  ASTHMA
  KIDNEY_DISEASE
  OTHER
}

enum GoalType {
  WEIGHT_LOSS
  WEIGHT_GAIN
  MUSCLE_GAIN
  GENERAL_WELLNESS
}

enum ActivityLevel {
  SEDENTARY
  LIGHTLY_ACTIVE
  MODERATELY_ACTIVE
  VERY_ACTIVE
}
