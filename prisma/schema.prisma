generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  provider      String
  providerId    String?  @unique
  role          UserRole @default(USER)

  fullName      String
  dateOfBirth   DateTime?
  gender        Gender?
  height        Float?
  weight        Float?
  activityLevel ActivityLevel?

  telegramChatId String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  lastLogin     DateTime?

  // Relations
  healthInfo        HealthInfo?
  goals             Goal[]
  diseases          Disease[]
  medications       Medication[]

  nutritionPlans    NutritionPlan[]
  exercisePlans     ExercisePlan[]
  sleepSchedules    SleepSchedule[]

  mealLogs          MealLog[]
  exerciseLogs      ExerciseLog[]
  sleepLogs         SleepLog[]

  reminders         Reminder[]
  weeklyReports     WeeklyReport[]
  snapshots         UserWeeklySnapshot[]

  aiRecommendations AIRecommendation[]
}

model HealthInfo {
  id                String   @id @default(uuid())
  userId            String   @unique
  hasChronicDisease Boolean
  allergies         String[]
  notes             String?

  createdAt         DateTime @default(now())

  user              User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Goal {
  id                   String     @id @default(uuid())
  userId               String
  goalType             GoalType
  focusArea            focusType?

  targetWeight         Float?
  targetDate           DateTime?
  muscleMassPercentage Int?

  description          String?
  createdAt            DateTime @default(now())

  user                 User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model NutritionPlan {
  id            String   @id @default(uuid())
  userId        String

  dailyCalories Int
  proteinGrams  Int
  carbsGrams    Int
  fatsGrams     Int

  isActive      Boolean  @default(true)
  version       Int      @default(1)

  startDate     DateTime
  createdAt     DateTime @default(now())

  meals         Meal[]
  user          User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Meal {
  id              String   @id @default(uuid())
  nutritionPlanId String

  mealName        String
  mealTime        DateTime
  description     String

  calories        Int
  protein         Int
  carbs           Int
  fats            Int

  createdAt       DateTime @default(now())

  nutritionPlan   NutritionPlan @relation(fields: [nutritionPlanId], references: [id], onDelete: Cascade)
  mealLogs        MealLog[]
  reminders       Reminder[]

  @@index([nutritionPlanId])
}

model ExercisePlan {
  id            String   @id @default(uuid())
  userId        String

  exerciseName  String
  exerciseType  String
  duration      Int
  scheduledTime DateTime

  instructions  String?
  createdAt     DateTime @default(now())

  user          User @relation(fields: [userId], references: [id], onDelete: Cascade)
  exerciseLogs  ExerciseLog[]
  reminders     Reminder[]

  @@index([userId])
}

model SleepSchedule {
  id          String   @id @default(uuid())
  userId      String

  bedTime     DateTime
  wakeTime    DateTime
  targetHours Float

  createdAt   DateTime @default(now())

  user        User @relation(fields: [userId], references: [id], onDelete: Cascade)
  reminders   Reminder[]

  @@index([userId])
}

model MealLog {
  id            String    @id @default(uuid())
  userId        String
  mealId        String

  status        LogStatus @default(PENDING)
  scheduledTime DateTime

  updatedAt     DateTime @updatedAt

  user          User @relation(fields: [userId], references: [id], onDelete: Cascade)
  meal          Meal @relation(fields: [mealId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([scheduledTime])
}

model ExerciseLog {
  id             String    @id @default(uuid())
  userId         String
  exercisePlanId String

  status         LogStatus @default(PENDING)
  scheduledTime  DateTime

  updatedAt      DateTime @updatedAt

  user           User @relation(fields: [userId], references: [id], onDelete: Cascade)
  exercisePlan   ExercisePlan @relation(fields: [exercisePlanId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([scheduledTime])
}

model SleepLog {
  id        String   @id @default(uuid())
  userId    String

  sleptAt   DateTime
  wakeAt    DateTime
  completed Boolean

  createdAt DateTime @default(now())

  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model WeeklyReport {
  id                String   @id @default(uuid())
  userId            String

  weekStart         DateTime
  weekEnd           DateTime

  mealsPlanned      Int
  mealsCompleted    Int

  workoutsPlanned   Int
  workoutsCompleted Int

  avgSleepHours     Float
  adherenceScore    Float

  createdAt         DateTime @default(now())

  user              User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, weekStart])
  @@index([userId])
}

model UserWeeklySnapshot {
  id            String   @id @default(uuid())
  userId        String

  weight        Float?
  activityLevel ActivityLevel?

  createdAt     DateTime @default(now())

  user          User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Reminder {
  id              String   @id @default(uuid())
  userId          String

  type            ReminderType
  reminderTime    DateTime

   sentAt          DateTime?      // When notification was sent
  completedAt     DateTime?      // When user marked as complete
  autoSkippedAt   DateTime?  

   status          ReminderStatus @default(PENDING)
  taskData        Json  

  mealId          String?
  exercisePlanId  String?
  sleepScheduleId String?
  medicationId    String?

  createdAt       DateTime @default(now())

  user          User @relation(fields: [userId], references: [id], onDelete: Cascade)
  meal          Meal?          @relation(fields: [mealId], references: [id])
  exercisePlan  ExercisePlan?  @relation(fields: [exercisePlanId], references: [id])
  sleepSchedule SleepSchedule? @relation(fields: [sleepScheduleId], references: [id])
  medication    Medication?    @relation(fields: [medicationId], references: [id])

  @@index([userId])
  @@index([reminderTime])
  @@index([userId, status])
  @@index([reminderTime, status])
  @@index([sentAt]) // For auto-skip processing
}

enum ReminderStatus {
  PENDING
  SENT
  COMPLETED
  SKIPPED
}
model AIRecommendation {
  id                 String   @id @default(uuid())
  userId             String

  recommendationType String
  recommendation     String

  createdAt          DateTime @default(now())

  user               User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Disease {
  id            String      @id @default(uuid())
  userId        String

  diseaseType   DiseaseType
  diseaseName   String
  diagnosedDate DateTime?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Medication {
  id             String   @id @default(uuid())
  userId         String

  medicationName String
  dosage         String

  createdAt      DateTime @default(now())

  user           User @relation(fields: [userId], references: [id], onDelete: Cascade)
  reminders      Reminder[]

  @@index([userId])
}

enum LogStatus {
  PENDING
  DONE
  SKIPPED
}

enum ReminderType {
  MEAL
  EXERCISE
  SLEEP
  MEDICATION
}

enum UserRole {
  USER
  ADMIN
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum GoalType {
  WEIGHT_LOSS
  WEIGHT_GAIN
  MUSCLE_GAIN
  GENERAL_WELLNESS
}

enum ActivityLevel {
  SEDENTARY
  LIGHTLY_ACTIVE
  MODERATELY_ACTIVE
  VERY_ACTIVE
}

enum DiseaseType {
  CANCER
  DIABETES
  HYPERTENSION
  HEART_DISEASE
  ASTHMA
  KIDNEY_DISEASE
  OTHER
}

enum focusType {
  ENERGY
  FLEXIBILITY
  STRENGTH
  MENTAL
  SLEEP
  OVERALL
}